class Solution {
public:
    vector<int> intersection(vector<int>& nums1, vector<int>& nums2) {
        vector<int>v;
        set<int>b;
        int n=nums1.size()-1;
        for(int i=0;i<=n;i++){
            b.insert(nums1[i]);
        }
        for(int i=0;i<nums2.size();i++){
            
                    if(b.find(nums2[i]) != b.end()){ v.push_back(nums2[i]);
                    b.erase(nums2[i]);}
        }
        return v;
        
    }
};
